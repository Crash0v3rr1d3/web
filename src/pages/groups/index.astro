---
import Layout from "../../layouts/Layout.astro";
import fs from 'node:fs';
import path from 'node:path';

let groupsFeed: any = [];
try {
    const groupsPath = path.resolve('./src/data/remote/groups.json');
    if (fs.existsSync(groupsPath)) {
        groupsFeed = JSON.parse(fs.readFileSync(groupsPath, 'utf8')) || [];
    } else {
        console.error("groups.json not found — run 'npm run sync:data' before building.");
    }
} catch (error) {
    console.error("Error reading groups data:", error);
}

// Sort alphabetically by group name
if (groupsFeed && groupsFeed.length > 0) {
    groupsFeed.sort((a: any, b: any) => {
        const nameA = a.name ? a.name.toLowerCase() : "";
        const nameB = b.name ? b.name.toLowerCase() : "";
        return nameA.localeCompare(nameB);
    });
}
---

<Layout
    title="Ransomware Groups - Crash0v3rr1d3"
    description="Index of active and inactive ransomware threat groups"
>
    <main
        class="w-full max-w-5xl mx-auto flex flex-col justify-start items-start gap-4 px-4 sm:px-0"
    >
        <a
            href="/"
            class="text-sm text-neutral-500 hover:text-white transition-colors duration-300 mb-8"
            >← Back to home</a
        >

        <div
            class="flex flex-col md:flex-row justify-between items-start md:items-end w-full mb-8 gap-4"
        >
            <div class="flex flex-col gap-2">
                <h1
                    class="font-bold text-3xl text-white glitch-hover"
                    data-text="Threat Actors"
                >
                    Threat Actors
                </h1>
                <p
                    class="text-[10px] text-neutral-600 leading-relaxed text-justify max-w-2xl mt-2"
                >
                    Legal Disclaimer: This site does not engage in the
                    acquisition, exfiltration, downloading, possession, hosting,
                    access, consultation, redistribution, or disclosure of
                    unlawfully obtained data. This platform indexes only
                    publicly visible information posted by ransomware operators
                    and open web sources without accessing or obtaining the
                    underlying stolen content. The service is provided to
                    support public awareness, legitimate research, and
                    cyber-resilience. No stolen personal or confidential data is
                    collected or distributed via this site.
                </p>
            </div>

            <div class="w-full md:w-64 relative shrink-0">
                <input
                    type="text"
                    id="group-search"
                    placeholder="Search groups..."
                    class="w-full bg-black/50 border border-neutral-800 text-white text-sm rounded-lg py-2 px-4 focus:outline-none focus:border-red-500/80 transition-colors font-mono placeholder-neutral-700"
                />
                <div
                    class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-neutral-600"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                        ></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Alphabet Filter -->
        <div
            class="flex flex-wrap gap-1 md:gap-2 w-full mb-8 p-3 rounded-lg border border-neutral-800/80 bg-black/30 items-center justify-center sm:justify-start"
        >
            <span
                class="text-xs text-neutral-500 font-mono mr-2 uppercase block w-full text-center sm:w-auto sm:text-left mb-2 sm:mb-0 hidden sm:block"
                >A-Z:</span
            >
            <button
                class="alpha-btn px-2 py-1 text-[10px] md:text-xs font-mono rounded bg-red-500/20 text-red-400 border border-red-500/30 transition-colors"
                data-char="all">ALL</button
            >
            <button
                class="alpha-btn px-2 py-1 text-[10px] md:text-xs font-mono rounded text-neutral-400 hover:bg-neutral-800 hover:text-white transition-colors"
                data-char="#">#</button
            >
            {
                Array.from("ABCDEFGHIJKLMNOPQRSTUVWXYZ").map((char) => (
                    <button
                        class="alpha-btn px-1.5 md:px-2 py-1 text-[10px] md:text-xs font-mono rounded text-neutral-400 hover:bg-neutral-800 hover:text-white transition-colors"
                        data-char={char}
                    >
                        {char}
                    </button>
                ))
            }
        </div>

        <div id="no-results" class="hidden w-full text-center py-12">
            <p class="text-red-500 font-mono animate-pulse">
                &gt;_ no groups found matching parameters
            </p>
        </div>

        <div
            id="groups-grid"
            class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
        >
            {
                groupsFeed.length > 0 ? (
                    groupsFeed.map((group: any) => (
                        <a
                            href={`/groups/${encodeURIComponent(group.name)}`}
                            class="group-card flex flex-col justify-between w-full bg-black/50 border border-neutral-800 hover:border-red-500/50 rounded-lg p-4 gap-4 transition-colors duration-300"
                            data-name={
                                group.name ? group.name.toLowerCase() : ""
                            }
                        >
                            <div class="flex flex-col gap-2">
                                <div class="flex items-center gap-2">
                                    <span class="text-white group-hover:text-red-500 transition-colors duration-300 font-bold truncate text-lg tracking-wide">
                                        <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 mr-1 text-red-500">
                                            [
                                        </span>
                                        <span class="group-hover:translate-x-1 transition-transform duration-300 inline-block truncate max-w-[90%]">
                                            {group.name}
                                        </span>
                                        <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 ml-1 text-red-500">
                                            ]
                                        </span>
                                    </span>
                                </div>
                            </div>

                            <div class="flex flex-col gap-2 mt-auto">
                                <div class="flex items-center gap-2 text-[10px] text-neutral-500 font-mono">
                                    <span class="w-3 h-3 rounded-full flex items-center justify-center bg-neutral-900 border border-neutral-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-500 shadow-[0_0_4px_#ef4444]" />
                                    </span>
                                    <span>
                                        {group.victims || 0} victims targeted
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))
                ) : (
                    <p class="text-red-500 font-mono col-span-full">
                        Failed to fetch group index from API.
                    </p>
                )
            }
        </div>
    </main>
</Layout>

<script>
    document.addEventListener("astro:page-load", () => {
        const searchInput = document.getElementById(
            "group-search"
        ) as HTMLInputElement;
        const groupCards = document.querySelectorAll(".group-card");
        const noResults = document.getElementById("no-results");
        const alphaBtns = document.querySelectorAll(".alpha-btn");
        let timeoutId: NodeJS.Timeout;
        let activeChar = "all";

        function filterGroups() {
            const query = searchInput
                ? searchInput.value.toLowerCase().trim()
                : "";
            let visibleCount = 0;

            groupCards.forEach((card) => {
                const htmlCard = card as HTMLElement;
                const name = htmlCard.getAttribute("data-name") || "";

                let matchesSearch = name.includes(query);
                let matchesAlpha = true;

                if (activeChar !== "all") {
                    if (activeChar === "#") {
                        matchesAlpha = /^[0-9]/.test(name);
                    } else {
                        matchesAlpha = name
                            .toUpperCase()
                            .startsWith(activeChar);
                    }
                }

                if (matchesSearch && matchesAlpha) {
                    htmlCard.style.display = "flex";
                    visibleCount++;
                } else {
                    htmlCard.style.display = "none";
                }
            });

            if (noResults) {
                if (visibleCount === 0) {
                    noResults.classList.remove("hidden");
                } else {
                    noResults.classList.add("hidden");
                }
            }
        }

        if (searchInput && groupCards.length > 0) {
            searchInput.addEventListener("keyup", () => {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(filterGroups, 150);
            });
        }

        if (alphaBtns.length > 0) {
            alphaBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    alphaBtns.forEach((b) => {
                        b.classList.remove(
                            "bg-red-500/20",
                            "text-red-400",
                            "border",
                            "border-red-500/30"
                        );
                        b.classList.add("text-neutral-400");
                        if (b !== btn) {
                            b.classList.add(
                                "hover:bg-neutral-800",
                                "hover:text-white"
                            );
                        }
                    });

                    btn.classList.add(
                        "bg-red-500/20",
                        "text-red-400",
                        "border",
                        "border-red-500/30"
                    );
                    btn.classList.remove(
                        "text-neutral-400",
                        "hover:bg-neutral-800",
                        "hover:text-white"
                    );

                    activeChar = btn.getAttribute("data-char") || "all";
                    filterGroups();
                });
            });
        }
    });
</script>
