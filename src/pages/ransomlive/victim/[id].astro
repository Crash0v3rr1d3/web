---
import Layout from "@/layouts/Layout.astro";
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  let allVictims: any[] = [];
  try {
    const p = path.resolve('./src/data/remote/all_victims.json');
    if (fs.existsSync(p)) allVictims = JSON.parse(fs.readFileSync(p, 'utf8'));
    else console.warn("all_victims.json not found — run 'npm run sync:data' before building.");
  } catch (e) { console.error("Error reading all_victims.json:", e); }

  return allVictims.map((victim) => {
    return {
      params: { id: victim.victim },
      props: { victim },
    };
  });
}

const { id } = Astro.params;
const { victim } = Astro.props;

if (!victim) {
  return Astro.redirect("/ransomlive");
}
---

<Layout 
  title={`${id} - Ransomware Victim Intel - Crash0v3rr1d3`}
  description={`Security intelligence and threat data for ransomware victim ${id}`}
>
  <main class="w-full max-w-4xl mx-auto px-4 py-8">
    <div class="flex flex-col gap-8">
      <!-- Header -->
      <div class="flex flex-col gap-4">
        <a href="/ransomlive" class="text-sm text-neutral-500 hover:text-white transition-colors duration-300 w-fit">
          ← Back to Radar
        </a>
        
        <div class="flex items-center gap-4 flex-wrap">
          <h1 class="text-4xl font-bold text-white font-['Iceland'] glitch-hover" data-text={id}>
            {id}
          </h1>
          {victim.group && (
            <a href={`/groups/${encodeURIComponent(victim.group)}`} class="text-xs bg-red-500/10 text-red-500 border border-red-500/20 px-3 py-1 rounded font-mono uppercase hover:bg-red-500/20 transition-all">
              Group: {victim.group}
            </a>
          )}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Main Content -->
        <div class="md:col-span-2 flex flex-col gap-6">
          <div class="bg-neutral-900/50 border border-neutral-800 p-6 rounded-lg relative overflow-hidden">
              <h2 class="text-xl font-bold text-white mb-4 border-b border-neutral-800 pb-2">Victim Profile</h2>
              <div class="flex flex-col gap-4 text-sm text-neutral-300">
                  <div class="flex justify-between border-b border-neutral-800/50 pb-2">
                      <span class="text-neutral-500">Discovery Date</span>
                      <span>{victim.discovered || "N/A"}</span>
                  </div>
                  <div class="flex justify-between border-b border-neutral-800/50 pb-2">
                      <span class="text-neutral-500">Attack Date</span>
                      <span>{victim.attackdate || "N/A"}</span>
                  </div>
                  {victim.domain && (
                      <div class="flex justify-between border-b border-neutral-800/50 pb-2">
                          <span class="text-neutral-500">Domain</span>
                          <span class="text-white font-mono">{victim.domain}</span>
                      </div>
                  )}
                  {victim.country && (
                      <div class="flex justify-between border-b border-neutral-800/50 pb-2">
                          <span class="text-neutral-500">Country</span>
                          <span class="flex items-center gap-2">
                            <span class="text-white">{victim.country}</span>
                          </span>
                      </div>
                  )}
                  <div class="flex flex-col gap-2 mt-2">
                      <span class="text-neutral-500">Description</span>
                      <div class="bg-black/50 p-4 rounded text-neutral-400 border border-neutral-800/50 leading-relaxed italic">
                          {victim.description || "No description available."}
                      </div>
                  </div>
                  <div class="flex flex-col gap-2">
                      <span class="text-neutral-500">Activity Notes</span>
                      <div class="bg-red-500/5 p-3 rounded font-mono text-xs text-red-400/80 border border-red-500/10">
                          {victim.activity || "No specific activity notes logged."}
                      </div>
                  </div>
              </div>
          </div>

          <!-- Legal Legend / Disclaimer -->
          <div class="bg-red-950/20 border border-red-900/30 p-6 rounded-lg">
              <div class="flex items-center gap-2 mb-3 text-red-500">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
                  <span class="text-xs font-bold uppercase tracking-widest">Legal Disclaimer</span>
              </div>
              <p class="text-[11px] leading-relaxed text-neutral-400 text-justify font-mono">
                  We do not engage in the acquisition, exfiltration, downloading, possession, hosting, access, consultation, redistribution, or disclosure of unlawfully obtained data. This platform indexes only publicly visible information posted by ransomware operators and open web sources without accessing or obtaining the underlying stolen content. The service is provided to support public awareness, legitimate research, and cyber-resilience. No stolen personal or confidential data is collected or distributed via this site. 
                  <span class="text-neutral-300 block mt-2">Please reach out to <a href="mailto:crash0v3rr1d3@icloud.com" class="text-red-400 underline hover:text-red-300 transition-colors">crash0v3rr1d3@icloud.com</a> to get your entry removed.</span>
              </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="flex flex-col gap-6">
          <div class="bg-neutral-900/50 border border-neutral-800 p-6 rounded-lg">
              <h3 class="text-xs uppercase tracking-widest text-neutral-500 mb-4 font-mono">External Intel</h3>
              <div class="flex flex-col gap-4 text-xs">
                  {victim.url && (
                    <div class="flex flex-col gap-1">
                        <span class="text-neutral-600 uppercase text-[10px]">Source Intel</span>
                        <a href={victim.url} target="_blank" class="text-neutral-400 hover:text-white truncate underline decoration-neutral-800 underline-offset-4">ransomware.live/id/...</a>
                    </div>
                  )}
                  {victim.claim_url && (
                    <div class="flex flex-col gap-1">
                        <span class="text-neutral-600 uppercase text-[10px]">Onion Leak Site</span>
                        <a href={victim.claim_url} target="_blank" class="text-neutral-400 hover:text-white truncate font-mono bg-black p-1 rounded border border-neutral-800">Visit Leak Site</a>
                    </div>
                  )}
                  <div class="flex flex-col gap-1">
                      <span class="text-neutral-600 uppercase text-[10px]">Tracking Since</span>
                      <span class="text-neutral-400">{victim.discovered?.split(' ')[0] || "Unknown"}</span>
                  </div>
              </div>
          </div>

          {victim.screenshot && (
            <div class="bg-neutral-900/50 border border-neutral-800 p-2 rounded-lg cursor-zoom-in group/screenshot relative">
              <img 
                src={victim.screenshot} 
                alt={`Evidence for ${id}`} 
                class="w-full rounded border border-neutral-800 grayscale hover:grayscale-0 transition-all duration-500 screenshot-trigger" 
                id="screenshot-img"
              />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/screenshot:opacity-100 transition-opacity pointer-events-none">
                <span class="bg-black/80 text-white text-[10px] px-2 py-1 rounded border border-neutral-700 font-mono uppercase">Click to Enlarge</span>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="screenshot-modal" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-sm hidden flex-col items-center justify-center p-4 cursor-zoom-out">
        <div class="relative w-full max-w-6xl max-h-[90vh] flex items-center justify-center">
            <img id="modal-img" src="" alt="Full size evidence" class="max-w-full max-h-full object-contain border border-neutral-800 shadow-2xl shadow-red-500/10 rounded" />
            <button id="close-modal" class="absolute -top-12 right-0 text-neutral-500 hover:text-white flex items-center gap-2 font-mono text-xs uppercase transition-colors">
                [ Close ] <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x text-red-500"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
        </div>
        <div class="mt-4 text-neutral-500 font-mono text-[10px] uppercase tracking-widest bg-neutral-900/50 px-4 py-2 rounded-full border border-neutral-800">
            Esc to close | Click anywhere to exit
        </div>
    </div>
  </main>
</Layout>

<script>
    const trigger = document.getElementById('screenshot-img');
    const modal = document.getElementById('screenshot-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const closeBtn = document.getElementById('close-modal');

    if (trigger && modal && modalImg) {
        trigger.addEventListener('click', () => {
            modalImg.src = (trigger as HTMLImageElement).src;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });

        const closeModal = () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = '';
        };

        modal.addEventListener('click', closeModal);
        closeBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            closeModal();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });
    }
</script>

<style>
    .glitch-hover:hover {
        animation: active 0.1s infinite;
    }
</style>
