            </div>

            <!-- No results message -->
            <div
                id="no-results"
                class="hidden py-20 text-center flex-col items-center gap-4"
            >
                <svg
                    class="text-neutral-800"
                    xmlns="http://www.w3.org/2000/svg"
                    width="48"
                    height="48"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="11" cy="11" r="8"></circle><path
                        d="m21 21-4.3-4.3"></path></svg
                >
                <p
                    class="text-neutral-600 font-mono uppercase tracking-widest text-xs"
                >
                    No matching vulnerabilities found
                </p>
            </div>
        </div>
    </main>
</Layout>

<script>
    // ─────────────────────────────────────────────────────────────
    // Security: Input Sanitisation & Guardrails
    // OWASP: XSS prevention — no innerHTML, no eval, no DOM injection
    //   • Whitelist: only alphanumeric, hyphens, dots, spaces allowed
    //   • Max length enforced at JS level (belt-and-suspenders with HTML attr)
    //   • Input is ONLY compared against pre-rendered dataset attributes
    //   • Output uses .textContent (safe) — never .innerHTML
    //   • Debounced to prevent performance abuse via rapid input
    //   • Paste events are sanitised before processing
    // ─────────────────────────────────────────────────────────────

    const SEARCH_MAX_LENGTH = 100;
    const ALLOWED_CHARS = /[^a-zA-Z0-9\s\-\.]/g; // whitelist pattern (inverted for stripping)
    const DEBOUNCE_MS = 150;

    /** Strip dangerous characters — whitelist approach (deny by default). */
    function sanitiseInput(raw: string): string {
        return raw
            .replace(ALLOWED_CHARS, "")  // strip anything not whitelisted
            .substring(0, SEARCH_MAX_LENGTH) // enforce max length
            .trim();
    }

    /** Validate YYYY-MM-DD date format strictly. */
    function isValidDateValue(val: string): boolean {
        if (!val) return true; // empty is valid (no filter)
        return /^\d{4}-\d{2}-\d{2}$/.test(val) && !isNaN(Date.parse(val));
    }

    /** Validate select value is one of the allowed options. */
    function isValidSelectValue(select: HTMLSelectElement): boolean {
        const options = Array.from(select.options).map((o) => o.value);
        return options.includes(select.value);
    }

    /** Simple debounce to prevent rapid-fire filtering. */
    function debounce(fn: (...args: any[]) => void, ms: number) {
        let timer: ReturnType<typeof setTimeout>;
        return (...args: any[]) => {
            clearTimeout(timer);
            timer = setTimeout(() => fn(...args), ms);
        };
    }

    // ── Toggle expand/collapse ──────────────────────────────────
    document.querySelectorAll(".cve-toggle").forEach((toggle) => {
        toggle.addEventListener("click", () => {
            const entry = toggle.closest(".cve-entry");
            if (!entry) return;
            const detail = entry.querySelector(".cve-detail");
            const chevron = entry.querySelector(".cve-chevron");
            if (detail) detail.classList.toggle("hidden");
            if (chevron) chevron.classList.toggle("rotate-180");
        });
    });

    // ── DOM references ──────────────────────────────────────────
    const searchInput = document.getElementById(
        "cve-search"
    ) as HTMLInputElement;
    const severityFilter = document.getElementById(
        "severity-filter"
    ) as HTMLSelectElement;
    const vendorFilter = document.getElementById(
        "vendor-filter"
    ) as HTMLSelectElement;
    const productFilter = document.getElementById(
        "product-filter"
    ) as HTMLSelectElement;
    const dateFrom = document.getElementById("date-from") as HTMLInputElement;
    const dateTo = document.getElementById("date-to") as HTMLInputElement;
    const resetBtn = document.getElementById("reset-filters");
    const entries = document.querySelectorAll(
        ".cve-entry"
    ) as NodeListOf<HTMLElement>;
    const noResults = document.getElementById("no-results");
    const resultsCount = document.getElementById("results-count");

    // ── Live sanitisation on keystroke ───────────────────────────
    // Immediately strips disallowed chars as the user types so
    // dangerous payloads never persist in the input field.
    searchInput?.addEventListener("input", () => {
        const cleaned = sanitiseInput(searchInput.value);
        if (cleaned !== searchInput.value) {
            searchInput.value = cleaned; // overwrite with sanitised value
        }
    });

    // ── Sanitise paste events ───────────────────────────────────
    // Intercept clipboard data before it reaches the input.
    searchInput?.addEventListener("paste", (e: ClipboardEvent) => {
        e.preventDefault();
        const pasted = e.clipboardData?.getData("text/plain") || "";
        const cleaned = sanitiseInput(pasted);
        // Insert sanitised text at cursor via execCommand-free approach
        const start = searchInput.selectionStart ?? searchInput.value.length;
        const end = searchInput.selectionEnd ?? start;
        const before = searchInput.value.substring(0, start);
        const after = searchInput.value.substring(end);
        searchInput.value = sanitiseInput(before + cleaned + after);
        searchInput.dispatchEvent(new Event("input")); // trigger filter update
    });

    // ── Core filter logic ───────────────────────────────────────
    function applyFilters() {
        // Sanitise search query (defence-in-depth — already cleaned on input)
        const query = sanitiseInput(searchInput.value).toLowerCase();

        // Validate select dropdowns against their actual option values
        const severity = isValidSelectValue(severityFilter)
            ? severityFilter.value
            : "all";
        const vendor = isValidSelectValue(vendorFilter)
            ? vendorFilter.value.toLowerCase()
            : "all";
        const product = isValidSelectValue(productFilter)
            ? productFilter.value.toLowerCase()
            : "all";

        // Validate date inputs
        const from = isValidDateValue(dateFrom.value) ? dateFrom.value : "";
        const to = isValidDateValue(dateTo.value) ? dateTo.value : "";

        let visible = 0;

        entries.forEach((el) => {
            // Read only from pre-rendered dataset attrs (server-controlled, safe)
            const id = el.dataset.id || "";
            const desc = el.dataset.desc || "";
            const date = el.dataset.date || "";
            const sev = el.dataset.severity || "";
            const vendors = el.dataset.vendors || "";
            const products = el.dataset.products || "";

            // String comparison only — no regex from user input, no DOM mutation
            const matchSearch =
                !query || id.includes(query) || desc.includes(query);
            const matchSeverity = severity === "all" || sev === severity;
            const matchVendor = vendor === "all" || vendors.includes(vendor);
            const matchProduct =
                product === "all" || products.includes(product);
            const matchFrom = !from || date >= from;
            const matchTo = !to || date <= to;

            if (
                matchSearch &&
                matchSeverity &&
                matchVendor &&
                matchProduct &&
                matchFrom &&
                matchTo
            ) {
                el.style.display = "";
                visible++;
            } else {
                el.style.display = "none";
            }
        });

        if (noResults) {
            noResults.classList.toggle("hidden", visible > 0);
            noResults.classList.toggle("flex", visible === 0);
        }
        // Safe: .textContent never interprets HTML/JS
        if (resultsCount) {
            resultsCount.textContent = `Showing ${visible} vulnerabilit${visible === 1 ? "y" : "ies"}`;
        }
    }

    // ── Event listeners (search is debounced) ───────────────────
    const debouncedFilter = debounce(applyFilters, DEBOUNCE_MS);
    searchInput?.addEventListener("input", debouncedFilter);
    severityFilter?.addEventListener("change", applyFilters);
    vendorFilter?.addEventListener("change", applyFilters);
    productFilter?.addEventListener("change", applyFilters);
    dateFrom?.addEventListener("change", applyFilters);
    dateTo?.addEventListener("change", applyFilters);

    resetBtn?.addEventListener("click", () => {
        searchInput.value = "";
        severityFilter.value = "all";
        vendorFilter.value = "all";
        productFilter.value = "all";
        dateFrom.value = "";
        dateTo.value = "";
        applyFilters();
    });
</script>

