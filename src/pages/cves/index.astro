                                                                Version
                                                            </th>
                                                            <th class="px-5 py-3 font-semibold">
                                                                Severity
                                                            </th>
                                                            <th class="px-5 py-3 font-semibold">
                                                                Vector
                                                            </th>
                                                            <th class="px-5 py-3 font-semibold text-center">
                                                                Exploitability
                                                            </th>
                                                            <th class="px-5 py-3 font-semibold text-center">
                                                                Impact
                                                            </th>
                                                            <th class="px-5 py-3 font-semibold text-right">
                                                                Source
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="divide-y divide-neutral-800/50">
                                                        {cve.cvssScores.map(
                                                            (cs: any) => (
                                                                <tr class="hover:bg-orange-500/[0.03] transition-colors">
                                                                    <td class="px-5 py-3">
                                                                        <span
                                                                            class={`inline-flex items-center justify-center w-10 h-10 rounded-md border-2 font-bold text-sm ${scoreColor(cs.score)}`}
                                                                        >
                                                                            {cs.score.toFixed(
                                                                                1
                                                                            )}
                                                                        </span>
                                                                    </td>
                                                                    <td class="px-5 py-3 text-sm font-mono text-neutral-300">
                                                                        {
                                                                            cs.version
                                                                        }
                                                                    </td>
                                                                    <td class="px-5 py-3">
                                                                        <span
                                                                            class={`text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider ${severityColor(cs.severity)}`}
                                                                        >
                                                                            {
                                                                                cs.severity
                                                                            }
                                                                        </span>
                                                                    </td>
                                                                    <td class="px-5 py-3 max-w-[220px]">
                                                                        <code class="text-[10px] font-mono text-neutral-400 bg-neutral-800/80 px-2 py-1 rounded block truncate" title={cs.vector}>
                                                                            {
                                                                                cs.vector
                                                                            }
                                                                        </code>
                                                                    </td>
                                                                    <td class="px-5 py-3 text-center">
                                                                        {cs.exploitabilityScore !==
                                                                        null ? (
                                                                            <span
                                                                                class={`inline-flex items-center justify-center w-10 h-10 rounded-md border ${scoreColor(cs.exploitabilityScore)} text-sm font-bold`}
                                                                            >
                                                                                {cs.exploitabilityScore.toFixed(
                                                                                    1
                                                                                )}
                                                                            </span>
                                                                        ) : (
                                                                            <span class="text-neutral-600 text-xs font-mono">
                                                                                —
                                                                            </span>
                                                                        )}
                                                                    </td>
                                                                    <td class="px-5 py-3 text-center">
                                                                        {cs.impactScore !==
                                                                        null ? (
                                                                            <span
                                                                                class={`inline-flex items-center justify-center w-10 h-10 rounded-md border ${scoreColor(cs.impactScore)} text-sm font-bold`}
                                                                            >
                                                                                {cs.impactScore.toFixed(
                                                                                    1
                                                                                )}
                                                                            </span>
                                                                        ) : (
                                                                            <span class="text-neutral-600 text-xs font-mono">
                                                                                —
                                                                            </span>
                                                                        )}
                                                                    </td>
                                                                    <td class="px-5 py-3 text-right">
                                                                        <span class="text-[11px] font-mono text-neutral-500 break-all">
                                                                            {
                                                                                cs.source
                                                                            }
                                                                        </span>
                                                                    </td>
                                                                </tr>
                                                            )
                                                        )}
                                                    </tbody>
                                                </table>
                                            </div>
                                        ) : (
                                            <div class="px-5 py-6 text-center">
                                                <p class="text-neutral-600 font-mono text-xs uppercase tracking-widest">
                                                    No CVSS scoring data
                                                    available yet
                                                </p>
                                            </div>
                                        )}
                                    </div>
                                </div>
                            );
                        })
                    ) : (
                        <div class="py-20 text-center flex flex-col items-center gap-4">
                            <p class="text-red-500 font-mono text-sm">
                                &gt;_ Error: Connection to intel feed severed.
                                Run `npm run sync:cves` to populate data.
                            </p>
