                                      cve.publishedDate
                                  ).toLocaleDateString("en-US", {
                                      year: "numeric",
                                      month: "short",
                                      day: "numeric",
                                  })
                                : "N/A";
                            const pubDateISO = cve.publishedDate
                                ? new Date(cve.publishedDate)
                                      .toISOString()
                                      .split("T")[0]
                                : "";

                            // Get highest severity from CVSS scores
                            const topSeverity =
                                cve.cvssScores?.[0]?.severity || "";
                            const topScore =
                                cve.cvssScores?.[0]?.score ?? null;

                            return (
                                <div
                                    class="cve-entry group bg-neutral-900/40 border border-neutral-800 rounded-lg hover:border-orange-500/30 transition-all"
