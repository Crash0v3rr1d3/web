---
import Layout from "@/layouts/Layout.astro";
import fs from "node:fs";
import path from "node:path";

let cvesData: any[] = [];
try {
    const p = path.resolve("./src/data/remote/cves.json");
    if (fs.existsSync(p))
        cvesData = JSON.parse(fs.readFileSync(p, "utf8"));
    else
        console.warn(
            "cves.json not found — run 'npm run sync:data' before building."
        );
} catch (e) {
    console.error("Error reading cves.json:", e);
}

// Sort by published date descending
const cves = cvesData.sort(
    (a, b) =>
        new Date(b.publishedDate).getTime() -
        new Date(a.publishedDate).getTime()
);

// Build unique filter options from data
const allVendors = [
    ...new Set(cves.flatMap((c: any) => c.vendors as string[])),
].sort();
const allProducts = [
    ...new Set(cves.flatMap((c: any) => c.products as string[])),
].sort();
const severityLevels = ["CRITICAL", "HIGH", "MEDIUM", "LOW"];

// Helper: severity → color classes
function severityColor(sev: string) {
    switch (sev?.toUpperCase()) {
        case "CRITICAL":
            return "bg-red-500 text-white";
        case "HIGH":
            return "bg-orange-500 text-white";
        case "MEDIUM":
            return "bg-yellow-500 text-black";
        case "LOW":
            return "bg-green-500 text-white";
        default:
            return "bg-neutral-600 text-white";
    }
}

function scoreColor(score: number) {
    if (score >= 9) return "border-red-500 text-red-400";
    if (score >= 7) return "border-orange-500 text-orange-400";
    if (score >= 4) return "border-yellow-500 text-yellow-400";
    if (score > 0) return "border-green-500 text-green-400";
    return "border-neutral-600 text-neutral-400";
}
---

<script>
    import { timeline, type TimelineDefinition } from "motion";
    import { loaderAnimation } from "@/lib/constants";
    const sequence = [loaderAnimation];
    timeline(sequence as TimelineDefinition);
</script>

<Layout title="0-Day Radar" description="Latest Vulnerability Disclosures">
    <main class="w-full max-w-6xl mx-auto px-4 py-12">
        <div class="flex flex-col gap-8">
            <!-- Header -->
            <div
                class="flex flex-col gap-4 border-l-4 border-orange-500 pl-6 py-2"
            >
                <div class="flex items-center gap-4">
                    <h1
                        class="text-5xl font-extrabold text-white tracking-tighter font-['Iceland']"
                    >
                        0-DAY RADAR <span class="text-orange-500">//</span> CVE INTEL
                    </h1>
                    <span
                        class="text-xs font-mono text-orange-500 bg-orange-500/10 border border-orange-500/30 px-2 py-1 rounded"
                        >LIVE_CVE</span
                    >
                </div>
                <p
                    class="text-neutral-500 font-mono text-sm max-w-2xl uppercase tracking-widest"
                >
                    Aggregated vulnerability disclosures with CVSS scoring data.
                    Sources: cvefeed.io + NVD.
                </p>
            </div>

            <!-- Filters -->
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 bg-neutral-900/30 p-6 rounded-lg border border-neutral-800"
                id="filter-panel"
            >
                <!-- Search CVE ID / Keyword -->
                <div class="lg:col-span-2">
                    <label
                        for="cve-search"
                        class="block text-[10px] uppercase tracking-widest text-neutral-600 mb-2 font-mono"
                        >Search CVE ID / Keyword</label
                    >
                    <div class="relative">
                        <input
                            type="text"
                            id="cve-search"
                            placeholder="CVE-2024-... or keyword"
                            maxlength="100"
                            autocomplete="off"
                            spellcheck="false"
                            pattern="[a-zA-Z0-9\s\-\.]*"
                            class="w-full bg-black border border-neutral-800 text-white px-4 py-3 rounded font-mono text-sm focus:outline-none focus:border-orange-500/50 transition-all pl-10"
                        />
                        <svg
                            class="absolute left-3 top-3.5 text-neutral-600"
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="11" cy="11" r="8"></circle><path
                                d="m21 21-4.3-4.3"></path></svg
