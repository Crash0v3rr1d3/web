                                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 px-5 py-4 cursor-pointer cve-toggle">
                                        <div class="flex items-center gap-4 min-w-0">
                                            {/* Score badge */}
                                            {topScore !== null ? (
                                                <div
                                                    class={`shrink-0 w-12 h-12 rounded-lg border-2 flex items-center justify-center font-bold text-lg ${scoreColor(topScore)}`}
                                                >
