                    >
                    <select
                        id="vendor-filter"
                        class="w-full bg-black border border-neutral-800 text-white px-4 py-3 rounded font-mono text-sm focus:outline-none focus:border-orange-500/50 transition-all appearance-none cursor-pointer"
                    >
