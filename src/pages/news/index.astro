---
import Layout from "@/layouts/Layout.astro";
import Parser from "rss-parser";
import { formatDate } from "@/lib/helpers";
import { NEWS_FEEDS } from "@/consts";

const parser = new Parser();
let newsFeed: any = [];

try {
    // Fetch from all feeds defined in consts.ts concurrently
    const feedPromises = NEWS_FEEDS.map((url) => parser.parseURL(url));
    const results = await Promise.allSettled(feedPromises);

    const allItems = results.reduce((acc: any[], result) => {
        if (result.status === "fulfilled") {
            return [...acc, ...result.value.items];
        }
        return acc;
    }, []);

    // Sort globally by date descending
    newsFeed = allItems
        .sort(
            (a, b) =>
                new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
        )
        .slice(0, 20); // Top 20 aggregated news
} catch (error) {
    console.error("Error fetching RSS feeds:", error);
}
---

<script>
    import { timeline, type TimelineDefinition } from "motion";
    import { loaderAnimation } from "@/lib/constants";

    const sequence = [loaderAnimation];

    timeline(sequence as TimelineDefinition);
</script>

<Layout title="InfoSec News" description="Latest Cybersecurity News Feed">
    <main
        class="w-screen h-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8 overflow-y-auto custom-scrollbar"
    >
        <a
            href="/"
            class="text-white bg-neutral-900 hover:bg-neutral-800 px-4 py-2 mb-8 border border-solid border-neutral-600 rounded-lg transition-colors"
            >Back</a
        >

        <div class="flex items-center gap-4 mb-4">
            <h1 class="text-4xl font-bold text-neutral-100">News Feed</h1>
            <span
                class="text-xs font-mono text-green-500 bg-green-500/10 border border-green-500/30 px-2 py-1 rounded"
                >LIVE_RSS</span
            >
        </div>

        <p class="text-neutral-400 text-sm mb-8 font-mono">
            >_ Aggregated infosec intel. Auto-updated via RSS build pipelines.
        </p>

        <ul class="w-full">
            {
                newsFeed.length > 0 ? (
                    newsFeed.map((entry: any) => (
                        <li class="group list-none w-full text-neutral-300 hover:text-green-500 transition-all duration-300 ease-in-out border-b border-dashed border-neutral-700 hover:border-green-500/50 my-2 py-1">
                            <a
                                class="text-sm md:text-base text-inherit flex justify-between items-center w-full"
                                href={entry.link}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <div class="flex items-center gap-2 overflow-hidden w-full">
                                    <div class="flex items-center">
                                        <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 mr-1 text-green-500 font-bold">
                                            [
                                        </span>
                                        <p class="inline-block whitespace-nowrap m-0 truncate group-hover:translate-x-1 transition-transform duration-300">
                                            {entry.title}
                                        </p>
                                        <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 ml-1 text-green-500 font-bold">
                                            ]
                                        </span>
                                    </div>
                                </div>
                                {entry.pubDate && (
                                    <time
                                        class="text-right tabular-nums text-xs group-hover:text-green-400 transition-colors duration-300 ml-4 shrink-0"
                                        datetime={new Date(
                                            entry.pubDate
                                        ).toISOString()}
                                    >
                                        {formatDate(new Date(entry.pubDate))}
                                    </time>
                                )}
                            </a>
                        </li>
                    ))
                ) : (
                    <p class="text-red-500 font-mono text-sm">
                        >_ Error: Connection to intel feed severed.
                    </p>
                )
            }
        </ul>
    </main>
</Layout>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 4px;
    }
</style>
