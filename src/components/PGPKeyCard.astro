---
import Card from "./Card/index.astro";
import { Icon } from "astro-icon/components";
---

<Card
  colSpan="md:col-span-1 lg:col-span-1"
  rowSpan="md:row-span-3"
  title="PGP Public Key"
>
  <div
    class="h-full w-full flex flex-col pt-2 cursor-pointer group"
    id="pgp-card-container"
  >
    <div
      class="flex items-center gap-2 mb-2 text-neutral-500 group-hover:text-green-500 transition-colors"
    >
      <Icon name="ri:key-2-fill" class="h-4 w-4" />
      <span class="text-xs font-mono tracking-wider">Click to Copy</span>
    </div>

    <div
      class="flex-1 overflow-hidden font-mono text-[10px] space-y-2 relative opacity-50 group-hover:opacity-100 transition-opacity"
    >
      <pre
        class="whitespace-pre-wrap overflow-hidden h-full text-green-500/80 custom-scrollbar pointer-events-none select-none">-----BEGIN PGP PUBLIC KEY BLOCK-----

[... Click anywhere to copy ...]

-----END PGP PUBLIC KEY BLOCK-----</pre>
    </div>
  </div>
</Card>

<script>
  document.addEventListener("astro:page-load", () => {
    const pgpCard = document.getElementById("pgp-card-container");
    const toast = document.getElementById("pgp-toast"); // Assuming toast is still in IntroCard or moved globally
    let keyText = "";

    pgpCard?.addEventListener("click", async () => {
      try {
        if (!keyText) {
          const res = await fetch("/pgp.txt");
          keyText = await res.text();
        }

        await navigator.clipboard.writeText(keyText);

        // Find or create toast locally for this card
        let localToast = document.getElementById("pgp-toast-card");
        if (!localToast) {
          localToast = document.createElement("div");
          localToast.id = "pgp-toast-card";
          localToast.className =
            "fixed bottom-4 right-4 bg-green-500/10 border border-green-500 text-green-500 px-4 py-3 rounded text-sm font-bold font-mono shadow-lg shadow-green-500/20 transform translate-y-[150%] transition-transform duration-300 ease-in-out z-[9999] flex items-center gap-2 pointer-events-none";
          localToast.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="h-5 w-5"><path fill="currentColor" d="M11.602 13.759L13.014 15.171L21.479 6.706L22.893 8.12L13.014 18L10.188 15.174L11.602 13.759ZM11.604 20L9.563 22.042L1.082 13.56L2.496 12.146L4.537 14.187L5.952 12.772L1.082 7.902L2.496 6.488L5.952 9.944L7.366 8.53L4.537 5.701L5.952 4.286L8.682 7.016L10.096 5.601L8.682 2.871L10.096 1.457L11.604 2.964L13.014 1.554L15.343 3.882L13.929 5.297L11.604 2.972L10.096 4.48L11.604 5.987L13.014 4.577L15.343 6.905L13.929 8.32L11.604 5.995L10.096 7.502L11.604 9.01L13.014 7.601L15.343 9.929L13.929 11.343L11.604 9.018L10.096 10.525L11.604 12.033L13.014 10.623L15.343 12.951L13.929 14.366L11.604 12.041L10.096 13.548Z"/></svg> <span>PGP KEY COPIED TO CLIPBOARD</span>`;
          document.body.appendChild(localToast);
        }

        // Show Toast
        localToast.classList.remove("translate-y-[150%]");
        localToast.classList.add("translate-y-0");

        // Hide Toast after 3 seconds
        setTimeout(() => {
          localToast.classList.remove("translate-y-0");
          localToast.classList.add("translate-y-[150%]");
        }, 3000);
      } catch (err) {
        console.error("Failed to fetch or copy PGP key: ", err);
      }
    });
  });
</script>
