<div
  class="text-center text-xs text-neutral-500 mt-8 mb-4 font-mono group cursor-default"
>
  <span
    class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 mr-1 text-green-500 font-bold"
    >[</span
  >You are Visitor #<span id="visitorCount" class="text-green-500 font-bold"
    >0</span
  ><span
    class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 ml-1 text-green-500 font-bold"
    >]</span
  >
</div>

<script>
  const countElement = document.getElementById("visitorCount");

  // Using localStorage to persist count
  let count = parseInt(localStorage.getItem("visitorCount") || "0");

  // Increment count on page load
  count++;
  localStorage.setItem("visitorCount", count.toString());

  if (countElement) {
    countElement.textContent = count.toString();
  }
</script>
