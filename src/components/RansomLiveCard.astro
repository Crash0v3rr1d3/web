---
import Card from "./Card/index.astro";
import { formatDate } from "@/lib/helpers";

interface Props {
    victims?: any[];
}

const { victims } = Astro.props;
---

<Card
    colSpan="md:col-span-2 lg:col-span-2"
    rowSpan="md:row-span-3"
    title="Ransom Live"
    href="/ransomlive"
>
    <div class="flex flex-col gap-2 mt-2 h-full overflow-hidden">
        <p class="text-xs text-neutral-400 font-mono mb-2 shrink-0">
            &gt;_ latest victims
        </p>
        <div class="flex-1 overflow-hidden flex flex-col gap-2">
            {
                victims && victims.length > 0 ? (
                    victims.map((entry: any) => (
                        <a
                            href={`/ransomlive/victim/${encodeURIComponent(entry.victim.replace(/\//g, '-'))}`}
                            class="group text-xs text-neutral-300 hover:text-red-500 transition-all duration-300 border-b border-neutral-800 hover:border-red-500/50 pb-2 last:border-0 flex overflow-hidden justify-between items-center"
                        >
                            <div class="flex items-center overflow-hidden flex-1 mr-2">
                                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 mr-1 text-red-500 font-bold shrink-0">
                                    [
                                </span>
                                <span
                                    class="truncate group-hover:translate-x-1 transition-transform duration-300"
                                    style="font-family: 'Iceland', cursive;"
                                >
                                    {entry.victim}
                                </span>
                                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 ml-1 text-red-500 font-bold shrink-0">
                                    ]
                                </span>
                            </div>
                            <span class="text-neutral-500 font-mono text-[10px] shrink-0 group-hover:text-red-400">
                                {entry.group}
                            </span>
                        </a>
                    ))
                ) : (
                    <p class="text-xs text-red-500 font-mono">
                        &gt;_ feed offline
                    </p>
                )
            }
        </div>
    </div>
</Card>
