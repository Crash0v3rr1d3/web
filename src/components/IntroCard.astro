---
import Card from "./Card/index.astro";
import Button from "./Button.astro";
import { LINKS } from "../lib/constants";
import { Icon } from "astro-icon/components";
import Tooltip from "./Tooltip/index";
import { Image } from "astro:assets";
---

<Card colSpan="md:col-span-2 lg:col-span-4" rowSpan="md:row-span-6">
  <div class="flex flex-col w-full h-full gap-4">
    <!-- Top Section: Text/Icons and Hacker Image -->
    <div class="flex w-full relative sm:min-h-[300px]">
      <div
        class="flex flex-col justify-between w-full md:w-1/2 gap-4 z-10 relative"
      >
        <div class="flex flex-col">
          <h6
            class="text-sm font-light m-0 text-gray-500 glitch-hover"
            data-text="welcome"
          >
            welcome
          </h6>
          <p class="m-0 font-light text-xl">
            Hello Friend!, I'm <b
              class="font-bold glitch-hover"
              style="font-family: 'Iceland', cursive;"
              data-text="Crash0v3rr1d3">Crash0v3rr1d3</b
            >, I'm a security enthusiast who loves to break stuff. I share
            things here.
          </p>
        </div>
        <div class="flex gap-4">
          <a aria-label="github profile" href={LINKS.github} target="_blank">
            <Button>
              <Icon class="h-6" name="ri:github-fill" />
              <span class="sr-only">GitHub Profile</span>
            </Button>
          </a>
          <a
            aria-label="linkedin profile"
            href={LINKS.linkedin}
            target="_blank"
          >
            <Button>
              <Icon class="h-6" name="ri:linkedin-box-fill" />
              <span class="sr-only">Linkedin Profile</span>
            </Button>
          </a>

          <a aria-label="rss feed" href="/rss.xml" target="_blank">
            <Button>
              <Icon class="h-6" name="ri:rss-fill" />
              <span class="sr-only">RSS Feed</span>
            </Button>
          </a>
          <a
            aria-label="x profile"
            href="https://x.com/Crash0verr1d3"
            target="_blank"
          >
            <Button>
              <Icon class="h-6" name="ri:twitter-x-line" />
              <span class="sr-only">X Profile</span>
            </Button>
          </a>
        </div>
      </div>
      <!-- Graphic Image -->
      <Image
        alt="Crash"
        class="w-auto max-h-[300px] select-none absolute right-[-110px] bottom-[-20px] z-[-1] opacity-50 md:opacity-100 md:relative md:right-auto md:bottom-auto md:z-auto pointer-events-none md:ml-auto"
        height="300"
        src="/hacker-ascii.gif"
        width="300"
      />
    </div>

    <!-- Embedded Terminal (Full Width Bottom) -->
    <div
      class="flex-1 w-full bg-black/50 border border-neutral-800 p-4 rounded flex flex-col relative z-20 overflow-hidden"
    >
      <div
        class="terminal-wrapper w-full h-full font-mono text-sm flex flex-col"
      >
        <!-- Title bar -->
        <div class="flex items-center gap-1.5 mb-3">
          <span class="w-3 h-3 rounded-full bg-red-500 opacity-80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500 opacity-80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500 opacity-80"></span>
          <span class="ml-2 text-xs text-neutral-500"
            ><span id="terminal-ip">crash0v3rr1d3</span>@kali:~</span
          >
        </div>

        <!-- Output log -->
        <div
          id="terminal-output"
          class="flex-1 overflow-y-auto text-xs space-y-1 custom-scrollbar"
        >
          <div class="text-primary-400">
            Welcome! Type <span class="text-white font-bold">help</span> to see available
            commands.
          </div>
        </div>

        <!-- Input line -->
        <div
          class="flex items-center mt-3 border-t border-primary-900 pt-2 shrink-0"
        >
          <span class="text-primary-400 mr-2 select-none">❯</span>
          <input
            id="terminal-input"
            type="text"
            class="flex-1 bg-transparent outline-none text-xs text-white caret-primary-400 selection:bg-primary-800 placeholder:text-neutral-600"
            placeholder="type a command..."
            autocomplete="off"
            spellcheck="false"
            aria-label="terminal input"
          />
        </div>
      </div>
    </div>
  </div>
</Card>

<style>
  .terminal-wrapper {
    letter-spacing: 0.02em;
  }
  .custom-scrollbar::-webkit-scrollbar {
    width: 3px;
    height: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--color-primary-800, #1a3a1a);
    border-radius: 3px;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    // Fetch public IP for the prompt
    fetch("https://api.ipify.org?format=json")
      .then((res) => res.json())
      .then((data) => {
        const ipSpan = document.getElementById("terminal-ip");
        if (ipSpan && data.ip) {
          ipSpan.textContent = data.ip;
        }
      })
      .catch(() => {});

    const COMMANDS: Record<string, () => string[]> = {
      help: () => [
        '<span class="text-primary-400">Available commands:</span>',
        '  <span class="text-yellow-400">whoami</span>           – who am i',
        '  <span class="text-yellow-400">skills</span>           – tech stack & expertise',
        '  <span class="text-yellow-400">ctf</span>              – recent CTF competitions',
        '  <span class="text-yellow-400">blog</span>             – latest blog posts',
        '  <span class="text-yellow-400">contact</span>          – how to reach me',
        '  <span class="text-yellow-400">clear</span>            – clear the terminal',
      ],
      whoami: () => [
        '<span class="text-primary-400">crash0v3rr1d3</span>',
        "Security researcher & CTF player.",
        "Interested in: web hacking, pwn, reverse engineering,",
        "network security, and cryptography.",
      ],
      skills: () => [
        '<span class="text-primary-400">Technical skills:</span>',
        "  [Web]     ──  XSS · SQLi · SSRF · IDOR · Deserialization",
        "  [Pwn]     ──  Buffer overflows · ROP chains · Heap exploitation",
        "  [Rev]     ──  Ghidra · IDA · GDB · angr",
        "  [Network] ──  Wireshark · Nmap · Burp Suite",
        "  [Stack]   ──  Python · Rust · Go · C · JavaScript",
      ],
      ctf: () => [
        '<span class="text-primary-400">Recent CTF activity:</span>',
        '  🏁  <span class="text-white">HackMac 2023</span> – 2nd place',
        '  🏁  <span class="text-white">NiteCTF 2023</span> – Top 10',
        '  🏁  <span class="text-white">SECCON 2023</span>  – Qualifier',
        '  🏁  <span class="text-white">WargamesMY</span>  – Active participant',
        "",
        'View writeups → <a class="text-primary-400 hover:underline" href="/writeups">/writeups</a>',
      ],
      blog: () => [
        '<span class="text-primary-400">Latest posts:</span>',
        '  → <a class="text-primary-400 hover:underline" href="/blog">Visit blog →</a>',
      ],
      contact: () => [
        '<span class="text-primary-400">Reach me at:</span>',
        "  Email  →  crash0v3rr1d3@icloud.com",
        "  GitHub →  github.com/crash0v3rr1d3",
      ],
      clear: () => {
        const output = document.getElementById("terminal-output")!;
        output.innerHTML = "";
        return [];
      },
    };

    function printLines(lines: string[]) {
      const output = document.getElementById("terminal-output");
      if (!output) return;
      lines.forEach((line) => {
        const el = document.createElement("div");
        el.innerHTML = line;
        el.className = "text-neutral-300 leading-relaxed";
        output.appendChild(el);
      });
      // Auto-scroll
      output.scrollTop = output.scrollHeight;
    }

    function printInput(val: string) {
      const output = document.getElementById("terminal-output");
      if (!output) return;
      const el = document.createElement("div");
      el.className = "flex gap-2 text-white";
      el.innerHTML = `<span class="text-primary-400 select-none">❯</span><span>${val}</span>`;
      output.appendChild(el);
    }

    const input = document.getElementById(
      "terminal-input"
    ) as HTMLInputElement | null;

    if (input) {
      // Remove previous listener before adding to prevent duplicates
      const new_element = input.cloneNode(true);
      input.parentNode?.replaceChild(new_element, input);
      const newInput = document.getElementById(
        "terminal-input"
      ) as HTMLInputElement;

      newInput.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key !== "Enter") return;
        const val = newInput.value.trim().toLowerCase();
        newInput.value = "";

        if (!val) return;

        printInput(val);

        if (val in COMMANDS) {
          const lines = COMMANDS[val]();
          printLines(lines);
        } else {
          printLines([
            `<span class="text-red-400">command not found: ${val}</span>`,
            'Type <span class="text-white">help</span> for available commands.',
          ]);
        }
        const output = document.getElementById("terminal-output");
        if (output) output.scrollTop = output.scrollHeight;
      });
    }
  });
</script>
