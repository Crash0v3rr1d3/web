---
import Card from "./Card/index.astro";
import { Icon } from "astro-icon/components";

interface Props {
  certs?: any[];
}
const { certs = [] } = Astro.props;

// Process CERTs for display
const processedCerts = certs.slice(0, 15).map((item) => {
  return {
    title: item.title,
    link: item.link,
    cert: item.cert,
    region: item.region,
    date: item.pubDate
  };
});
---

<Card
  colSpan="md:col-span-1 lg:col-span-2"
  rowSpan="md:row-span-3"
  title="CERT Alerts"
  href="/certs"
>
  <div class="h-full w-full flex flex-col pt-2">
    <div class="flex items-center gap-2 mb-2">
      <Icon
        name="ri:shield-flash-line"
        class="h-4 w-4 text-green-500 animate-pulse"
      />
      <span class="text-xs text-green-500 font-mono tracking-wider"
        >Global CERT Intelligence</span
      >
    </div>

    <div
      id="cert-ticker"
      class="flex-1 overflow-hidden font-mono text-[10px] space-y-2 relative"
      data-certs={JSON.stringify(processedCerts)}
    >
      <div class="text-neutral-500 mb-1 animate-pulse">
        Polling CERT signals...
      </div>
    </div>
  </div>
</Card>

<style>
  @keyframes slide-right {
    0% {
      transform: translateX(-10px);
      opacity: 0;
    }
    100% {
      transform: translateX(0);
      opacity: 1;
    }
  }
  .cert-item {
    animation: slide-right 0.5s ease-out forwards;
  }
</style>

<script>
  const container = document.getElementById("cert-ticker");

  if (container) {
    const certsRaw = container.getAttribute("data-certs");
    let certPool: any[] = [];

    if (certsRaw) {
      try {
        certPool = JSON.parse(certsRaw);
      } catch (e) {}
    }

    let currentIndex = 0;

    function renderCERT() {
      if (!container || certPool.length === 0) return;

      const item = certPool[currentIndex];
      currentIndex = (currentIndex + 1) % certPool.length;

      const div = document.createElement("div");
      div.className =
        "flex flex-col border-l-2 border-neutral-700 pl-2 cert-item";
      div.innerHTML = `
        <a href="${item.link}" target="_blank" rel="noopener noreferrer" class="group flex flex-col hover:border-l-green-500 transition-colors">
          <div class="flex justify-between w-full">
            <span class="font-bold text-white group-hover:text-green-400 transition-colors" style="font-family: 'Iceland', cursive;">${item.cert}</span>
            <span class="text-[8px] text-neutral-600 group-hover:text-green-500 transition-colors">${item.region}</span>
          </div>
          <span class="text-neutral-400 group-hover:text-neutral-300 whitespace-nowrap overflow-hidden text-ellipsis transition-colors">${item.title}</span>
        </a>
      `;

      // Clear loading state if present
      const loadingMessage = container.querySelector(".animate-pulse");
      if (loadingMessage) loadingMessage.remove();

      container.insertBefore(div, container.firstChild);

      // Keep only top 4 visible
      if (container.children.length > 4) {
        container.lastChild?.remove();
      }
    }

    // Initial Render
    for (let i = 0; i < Math.min(4, certPool.length); i++) {
      setTimeout(renderCERT, i * 400);
    }

    // Rotate one out every 5 seconds
    setInterval(renderCERT, 5000);
  }
</script>
