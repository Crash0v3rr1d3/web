---
import Card from "./Card/index.astro";
import { Icon } from "astro-icon/components";

interface Props {
    pocs?: any[];
}
const { pocs = [] } = Astro.props;

// Process PoCs for display
const processedPocs = pocs.slice(0, 15).map((poc) => {
    return {
        id: poc.cve_id || "VULN",
        name: poc.name,
        link: poc.html_url,
        stars: poc.stargazers_count
    };
});
---

<Card
    colSpan="md:col-span-1 lg:col-span-2"
    rowSpan="md:row-span-3"
    title="Exploit Feed"
    href="/pocs"
>
    <div class="h-full w-full flex flex-col pt-2">
        <div class="flex items-center gap-2 mb-2">
            <Icon
                name="ri:bug-line"
                class="h-4 w-4 text-green-500 animate-pulse"
            />
            <span class="text-xs text-green-500 font-mono tracking-wider"
                >Live PoC Index</span
            >
        </div>

        <div
            id="poc-ticker"
            class="flex-1 overflow-hidden font-mono text-[10px] space-y-2 relative"
            data-pocs={JSON.stringify(processedPocs)}
        >
            <div class="text-neutral-500 mb-1 animate-pulse">
                Indexing exploits...
            </div>
        </div>
    </div>
</Card>

<style>
    @keyframes slide-right {
        0% {
            transform: translateX(-10px);
            opacity: 0;
        }
        100% {
            transform: translateX(0);
            opacity: 1;
        }
    }
    .poc-item {
        animation: slide-right 0.5s ease-out forwards;
    }
</style>

<script>
    const container = document.getElementById("poc-ticker");

    if (container) {
        const pocsRaw = container.getAttribute("data-pocs");
        let pocPool: any[] = [];

        if (pocsRaw) {
            try {
                pocPool = JSON.parse(pocsRaw);
            } catch (e) {}
        }

        let currentIndex = 0;

        function renderPoC() {
            if (!container || pocPool.length === 0) return;

            const poc = pocPool[currentIndex];
            currentIndex = (currentIndex + 1) % pocPool.length;

            const div = document.createElement("div");
            div.className =
                "flex flex-col border-l-2 border-neutral-700 pl-2 poc-item";
            div.innerHTML = `
        <a href="${poc.link}" target="_blank" rel="noopener noreferrer" class="group flex flex-col hover:border-l-green-500 transition-colors">
          <div class="flex justify-between w-full">
            <span class="font-bold text-white group-hover:text-green-400 transition-colors" style="font-family: 'Iceland', cursive;">${poc.id}</span>
            <span class="text-[8px] text-neutral-600 group-hover:text-green-500 transition-colors">⭐ ${poc.stars}</span>
          </div>
          <span class="text-neutral-400 group-hover:text-neutral-300 whitespace-nowrap overflow-hidden text-ellipsis transition-colors">${poc.name}</span>
        </a>
      `;

            // Clear loading state if present
            const loadingMessage = container.querySelector(".animate-pulse");
            if (loadingMessage) loadingMessage.remove();

            container.insertBefore(div, container.firstChild);

            // Keep only top 4 visible
            if (container.children.length > 4) {
                container.lastChild?.remove();
            }
        }

        // Initial Render
        for (let i = 0; i < Math.min(4, pocPool.length); i++) {
            setTimeout(renderPoC, i * 400);
        }

        // Rotate one out every 5 seconds
        setInterval(renderPoC, 5000);
    }
</script>
