---
import Card from "@/components/Card/index.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/helpers";

const writeups = (await getCollection("writeups"))?.sort(
  (blogEntryA, blogEntryB) =>
    (blogEntryB.data.pubDate || new Date()).getTime() -
    (blogEntryA.data.pubDate || new Date()).getTime()
);
---

<Card
  colSpan="md:col-span-1 lg:col-span-1"
  rowSpan="md:row-span-6"
  title="Writeups."
  style="background-image: url('ctf-bg.webp'); background-size: cover; background-position: center; background-repeat: no-repeat; "
  href="/writeups"
>
  <div class="flex flex-col sm:max-h-none gap-4 overflow-hidden">
    {
      writeups?.slice(0, 3).map((writeup, index) => (
        <a
          href={`/writeups/${writeup.id}`}
          class={`group ${index >= 3 ? "hidden sm:block" : ""}`}
        >
          <div class="w-full text-neutral-300 hover:text-green-500 hover:border-green-500 ease-in-out transition-all duration-300 my-0 shadow-custom shadow-gray-700 bg-gray-900 border border-primary-500 pl-1 pr-2 flex justify-between items-center py-2">
            <div class="flex items-center gap-2 px-3 overflow-hidden">
              <div class="flex items-center">
                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 mr-1 text-green-500 font-bold">
                  [
                </span>
                <p class="inline-block font-bold text-sm m-0 group-hover:translate-x-1 transition-transform duration-300 truncate">
                  {writeup.data.title}
                </p>
                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 ml-1 text-green-500 font-bold">
                  ]
                </span>
              </div>
              {writeup.data.difficulty && (
                <span
                  class={`text-[10px] px-2 py-0.5 rounded-full border ${
                    writeup.data.difficulty.toLowerCase() === "easy"
                      ? "text-green-400 border-green-400/50 bg-green-400/10"
                      : writeup.data.difficulty.toLowerCase() === "medium"
                      ? "text-yellow-400 border-yellow-400/50 bg-yellow-400/10"
                      : "text-red-400 border-red-400/50 bg-red-400/10"
                  }`}
                >
                  {writeup.data.difficulty}
                </span>
              )}
              {writeup.data.tags &&
                writeup.data.tags
                  .slice(0, 1)
                  .map((tag) => (
                    <span class="text-[10px] text-primary-400 border border-primary-500/50 bg-primary-500/10 px-2 py-0.5 rounded-full">
                      {tag}
                    </span>
                  ))}
            </div>
            {writeup.data.pubDate && (
              <time
                class="tabular-nums text-xs"
                datetime={writeup.data.pubDate.toISOString()}
                data-date={writeup.data.pubDate.toISOString()}
              >
                {formatDate(writeup.data.pubDate)}
              </time>
            )}
          </div>
        </a>
      ))
    }
  </div>
</Card>
